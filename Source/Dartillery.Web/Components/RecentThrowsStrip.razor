@using Dartillery.Core.Enums
@using Dartillery.Web.Services

<div class="recent-strip">
    <div class="strip-header">
        <i class="bi bi-list-ul"></i>
        <span>Recent</span>
    </div>
    @if (SimulationService.ThrowCount > 0)
    {
        <div class="strip-list">
            @foreach (var t in SimulationService.Throws.TakeLast(12).Reverse())
            {
                <div class="strip-item @(!t.IsHit ? "miss" : "")">
                    <span class="strip-score">@t.Score</span>
                    <span class="strip-seg">@Abbrev(t.SegmentType)</span>
                    <span class="strip-sector">@(t.SectorNumber > 0 ? t.SectorNumber.ToString() : "-")</span>
                    @if (t.Metadata?.PressureModifier > 1.01)
                    {
                        <span class="strip-pressure @PressureDotClass(t.Metadata.PressureModifier)"
                              title="Pressure x@(t.Metadata.PressureModifier.ToString("F2"))"></span>
                    }
                </div>
            }
        </div>
    }
</div>

@code {
    [Parameter] public SimulationService SimulationService { get; set; } = null!;

    private static string Abbrev(SegmentType s) => s switch
    {
        SegmentType.InnerBull => "DB",
        SegmentType.OuterBull => "SB",
        SegmentType.Triple => "T",
        SegmentType.Double => "D",
        SegmentType.Single => "S",
        SegmentType.Miss => "X",
        _ => "?"
    };

    private static string PressureDotClass(double modifier) => modifier switch
    {
        > 1.1 => "pressure-high",
        > 1.01 => "pressure-mid",
        _ => ""
    };
}
