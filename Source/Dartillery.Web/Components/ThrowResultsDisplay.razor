@using Dartillery.Core.Models
@using Dartillery.Web.Services
@using Dartillery.Core.Enums

<div class="results-display">
    <!-- Header -->
    <div class="results-header">
        <h2 class="results-title">
            <i class="bi bi-bar-chart-fill"></i>
            Statistics
        </h2>
    </div>

    @if (SimulationService.ThrowCount == 0)
    {
        <div class="empty-state">
            <i class="bi bi-arrow-left-circle"></i>
            <p>Start throwing darts to see results</p>
        </div>
    }
    else
    {
        <!-- Stats Grid -->
        <div class="stats-grid">
            <div class="stat-card">
                <div class="stat-icon">
                    <i class="bi bi-hash"></i>
                </div>
                <div class="stat-content">
                    <div class="stat-label">Throws</div>
                    <div class="stat-value">@SimulationService.ThrowCount</div>
                </div>
            </div>

            <div class="stat-card">
                <div class="stat-icon">
                    <i class="bi bi-star-fill"></i>
                </div>
                <div class="stat-content">
                    <div class="stat-label">Average</div>
                    <div class="stat-value">@SimulationService.AverageScore.ToString("F1")</div>
                </div>
            </div>

            <div class="stat-card">
                <div class="stat-icon">
                    <i class="bi bi-bullseye"></i>
                </div>
                <div class="stat-content">
                    <div class="stat-label">Hit Rate</div>
                    <div class="stat-value">@((SimulationService.HitRate * 100).ToString("F0"))%</div>
                </div>
            </div>
        </div>

        <!-- Last Throw Card -->
        @if (SimulationService.LastThrow != null)
        {
            var lastThrow = SimulationService.LastThrow;
            <div class="last-throw-card">
                <div class="last-throw-header">
                    <span><i class="bi bi-clock-history"></i> Last Throw</span>
                    <span class="score-badge @GetScoreClass(lastThrow.Score)">
                        @lastThrow.Score
                    </span>
                </div>
                <div class="last-throw-details">
                    <div class="detail-item">
                        <i class="bi bi-segmented-nav"></i>
                        <span>@GetSegmentTypeName(lastThrow.SegmentType)</span>
                    </div>
                    @if (lastThrow.SectorNumber > 0)
                    {
                        <div class="detail-item">
                            <i class="bi bi-circle-fill"></i>
                            <span>Sector @lastThrow.SectorNumber</span>
                        </div>
                    }
                    <div class="detail-item">
                        <i class="bi bi-rulers"></i>
                        <span>Deviation: @lastThrow.Deviation.ToString("F3")</span>
                    </div>
                    <div class="detail-item">
                        <i class="bi bi-@(lastThrow.IsHit ? "check-circle-fill" : "x-circle-fill")"></i>
                        <span>@(lastThrow.IsHit ? "Hit" : "Miss")</span>
                    </div>
                </div>
            </div>
        }

        <!-- Recent Throws -->
        <div class="recent-throws">
            <div class="recent-throws-header">
                <i class="bi bi-list-ul"></i>
                Recent Throws
            </div>
            <div class="throws-list">
                @foreach (var throw_ in SimulationService.Throws.TakeLast(20).Reverse())
                {
                    <div class="throw-item @(!throw_.IsHit ? "miss" : "")">
                        <span class="throw-score">@throw_.Score</span>
                        <span class="throw-segment">@GetSegmentTypeAbbreviation(throw_.SegmentType)</span>
                        <span class="throw-sector">@(throw_.SectorNumber > 0 ? throw_.SectorNumber.ToString() : "-")</span>
                    </div>
                }
            </div>
        </div>
    }
</div>

@code {
    [Parameter] public SimulationService SimulationService { get; set; } = null!;

    private static string GetScoreClass(int score)
    {
        return score switch
        {
            >= 60 => "score-high",
            >= 40 => "score-medium",
            > 0 => "score-low",
            _ => "score-miss"
        };
    }

    private static string GetSegmentTypeName(SegmentType segmentType)
    {
        return segmentType switch
        {
            SegmentType.InnerBull => "Bullseye",
            SegmentType.OuterBull => "Outer Bull",
            SegmentType.Triple => "Triple",
            SegmentType.Double => "Double",
            SegmentType.Single => "Single",
            SegmentType.Miss => "Miss",
            _ => "Unknown"
        };
    }

    private static string GetSegmentTypeAbbreviation(SegmentType segmentType)
    {
        return segmentType switch
        {
            SegmentType.InnerBull => "DB",
            SegmentType.OuterBull => "SB",
            SegmentType.Triple => "T",
            SegmentType.Double => "D",
            SegmentType.Single => "S",
            SegmentType.Miss => "X",
            _ => "?"
        };
    }
}
