@using Dartillery.Core.Models
@using Dartillery.Web.Services

<div class="simulation-controls">
    <!-- Header -->
    <div class="controls-header">
        <h2 class="controls-title">
            <i class="bi bi-gear-fill"></i>
            Controls
        </h2>
    </div>

    <!-- Player Skill Section -->
    <div class="control-section">
        <div class="section-header">
            <i class="bi bi-person-badge"></i>
            <h3>Player Skill</h3>
        </div>
        <div class="section-content">
            <div class="form-group">
                <label for="skillLevel" class="form-label">Skill Level</label>
                <select id="skillLevel"
                        class="form-select"
                        @bind="SimulationService.SelectedSkillLevel"
                        @bind:after="OnSkillLevelChanged">
                    <option value="Professional">Professional (σ=0.02)</option>
                    <option value="Amateur">Amateur (σ=0.05)</option>
                    <option value="Beginner">Beginner (σ=0.08)</option>
                    <option value="Custom">Custom</option>
                </select>
            </div>

            @if (SimulationService.SelectedSkillLevel == "Custom")
            {
                <div class="form-group">
                    <label for="customSigma" class="form-label">
                        Sigma: @_customSigmaDisplay.ToString("0.000")
                    </label>
                    <input id="customSigma"
                           type="range"
                           class="form-range"
                           value="@_customSigmaDisplay.ToString(System.Globalization.CultureInfo.InvariantCulture)"
                           @oninput="OnCustomSigmaInput"
                           @onchange="OnParameterChanged"
                           min="0.01"
                           max="0.25"
                           step="0.001" />
                    <small class="form-text">Lower = more accurate</small>
                </div>
            }
        </div>
    </div>

    <!-- Target Selection Section -->
    <div class="control-section">
        <div class="section-header">
            <i class="bi bi-bullseye"></i>
            <h3>Target Selection</h3>
        </div>
        <div class="section-content">
            <div class="form-check mb-3">
                <input class="form-check-input"
                       type="checkbox"
                       id="enableManualTargeting"
                       @bind="SimulationService.EnableManualTargeting"
                       @bind:after="OnParameterChanged" />
                <label class="form-check-label" for="enableManualTargeting">
                    Manual Targeting (Click on dartboard)
                </label>
            </div>

            @if (!SimulationService.EnableManualTargeting)
            {
                <div class="form-group">
                    <label for="targetSelect" class="form-label">Target</label>
                    <select id="targetSelect" class="form-select" @bind="SelectedTarget">
                        <option value="T20">Triple 20</option>
                        <option value="T19">Triple 19</option>
                        <option value="T18">Triple 18</option>
                        <option value="Bull">Bullseye</option>
                        <option value="OuterBull">Outer Bull</option>
                        <option value="D20">Double 20</option>
                        <option value="D16">Double 16</option>
                        <option value="S20">Single 20</option>
                        <option value="S19">Single 19</option>
                        <option value="S1">Single 1</option>
                    </select>
                </div>
            }
        </div>
    </div>

    <!-- Actions Section -->
    <div class="control-section">
        <div class="section-header">
            <i class="bi bi-play-circle"></i>
            <h3>Actions</h3>
        </div>
        <div class="section-content">
            <div class="action-buttons">
                <button @onclick="ThrowDart" class="btn-action btn-primary" type="button">
                    <i class="bi bi-bullseye"></i>
                    <span>Throw Dart</span>
                </button>
                <button @onclick="Throw10Darts" class="btn-action btn-secondary" type="button">
                    <i class="bi bi-arrow-repeat"></i>
                    <span>10 Darts</span>
                </button>
                <button @onclick="ClearThrows" class="btn-action btn-danger" type="button">
                    <i class="bi bi-trash"></i>
                    <span>Clear All</span>
                </button>
            </div>
        </div>
    </div>

    <!-- Advanced Effects Section (Collapsible) -->
    <div class="control-section">
        <div class="section-header expandable" @onclick="ToggleEffects">
            <i class="bi bi-lightning"></i>
            <h3>Advanced Effects</h3>
            <i class="bi bi-chevron-@(showEffects ? "up" : "down")" style="margin-left: auto;"></i>
        </div>
        @if (showEffects)
        {
            <div class="section-content">
                <!-- Fatigue -->
                <div class="form-check mb-3">
                    <input class="form-check-input"
                           type="checkbox"
                           id="enableFatigue"
                           @bind="SimulationService.EnableFatigue"
                           @bind:after="OnParameterChanged" />
                    <label class="form-check-label" for="enableFatigue">
                        Enable Fatigue Simulation
                    </label>
                </div>

                @if (SimulationService.EnableFatigue)
                {
                    <div class="form-group">
                        <label for="fatigueRate" class="form-label">
                            Fatigue Rate: @_fatigueRateDisplay.ToString("0.0000")
                        </label>
                        <input id="fatigueRate"
                               type="range"
                               class="form-range"
                               value="@_fatigueRateDisplay.ToString(System.Globalization.CultureInfo.InvariantCulture)"
                               @oninput="OnFatigueRateInput"
                               @onchange="OnParameterChanged"
                               min="0.001"
                               max="0.02"
                               step="0.001" />
                        <small class="form-text">How quickly player tires</small>
                    </div>

                    <div class="alert alert-info">
                        <strong>Current Tremor:</strong> @SimulationService.CurrentTremor.ToString("F4")
                        <div class="progress">
                            <div class="progress-bar"
                                 role="progressbar"
                                 style="width: @((SimulationService.CurrentTremor * 100).ToString("F0"))%"
                                 aria-valuenow="@((SimulationService.CurrentTremor * 100).ToString("F0"))"
                                 aria-valuemin="0"
                                 aria-valuemax="100">
                                @((SimulationService.CurrentTremor * 100).ToString("F0"))%
                            </div>
                        </div>
                    </div>

                    <button @onclick="Throw50Darts" class="btn-action btn-secondary" type="button" style="width: 100%; margin-top: var(--spacing-sm);">
                        <i class="bi bi-arrow-repeat"></i>
                        <span>Fatigue Test (50 throws)</span>
                    </button>
                }

                <!-- Pressure -->
                <div class="form-check" style="margin-top: var(--spacing-md);">
                    <input class="form-check-input"
                           type="checkbox"
                           id="enablePressure"
                           @bind="SimulationService.EnablePressure"
                           @bind:after="OnParameterChanged" />
                    <label class="form-check-label" for="enablePressure">
                        Enable Pressure Psychology
                    </label>
                </div>

                @if (SimulationService.EnablePressure)
                {
                    <div class="alert alert-warning" style="margin-top: var(--spacing-sm);">
                        <small>
                            <i class="bi bi-info-circle"></i>
                            Pressure effects simulate psychological impact during high-stakes throws.
                        </small>
                    </div>
                }
            </div>
        }
    </div>
</div>

@code {
    [Parameter] public SimulationService SimulationService { get; set; } = null!;
    [Parameter] public EventCallback OnThrowExecuted { get; set; }

    private string SelectedTarget { get; set; } = "T20";
    private bool showEffects = false;
    private double _customSigmaDisplay;
    private double _fatigueRateDisplay;
    private bool _isSliding = false;

    protected override void OnParametersSet()
    {
        if (!_isSliding)
        {
            _customSigmaDisplay = SimulationService.CustomSigma;
            _fatigueRateDisplay = SimulationService.FatigueRate;
        }
    }

    private void ToggleEffects()
    {
        showEffects = !showEffects;
    }

    private void OnCustomSigmaInput(ChangeEventArgs e)
    {
        _isSliding = true;
        if (double.TryParse(e.Value?.ToString(), System.Globalization.NumberStyles.Any, System.Globalization.CultureInfo.InvariantCulture, out double value))
        {
            _customSigmaDisplay = value;
            SimulationService.CustomSigma = value;
        }
    }

    private void OnFatigueRateInput(ChangeEventArgs e)
    {
        _isSliding = true;
        if (double.TryParse(e.Value?.ToString(), System.Globalization.NumberStyles.Any, System.Globalization.CultureInfo.InvariantCulture, out double value))
        {
            _fatigueRateDisplay = value;
            SimulationService.FatigueRate = value;
        }
    }

    private async Task OnSkillLevelChanged()
    {
        SimulationService.RebuildSession();
        await OnThrowExecuted.InvokeAsync();
    }

    private async Task OnParameterChanged()
    {
        _isSliding = false;
        SimulationService.RebuildSession();
        await OnThrowExecuted.InvokeAsync();
    }

    private async Task ThrowDart()
    {
        var target = ParseTarget(SelectedTarget);
        SimulationService.ThrowAt(target);
        await OnThrowExecuted.InvokeAsync();
    }

    private async Task Throw10Darts()
    {
        var target = ParseTarget(SelectedTarget);
        for (int i = 0; i < 10; i++)
        {
            SimulationService.ThrowAt(target);
            await Task.Yield();
        }
        await OnThrowExecuted.InvokeAsync();
    }

    private async Task Throw50Darts()
    {
        var target = ParseTarget(SelectedTarget);
        for (int i = 0; i < 50; i++)
        {
            SimulationService.ThrowAt(target);
            if (i % 5 == 0)
            {
                await OnThrowExecuted.InvokeAsync();
                await Task.Delay(50);
            }
        }
        await OnThrowExecuted.InvokeAsync();
    }

    private async Task ClearThrows()
    {
        SimulationService.ClearThrows();
        await OnThrowExecuted.InvokeAsync();
    }

    private static Target ParseTarget(string targetStr)
    {
        return targetStr switch
        {
            "T20" => Target.Triple(20),
            "T19" => Target.Triple(19),
            "T18" => Target.Triple(18),
            "Bull" => Target.Bullseye(),
            "OuterBull" => Target.OuterBull(),
            "D20" => Target.Double(20),
            "D16" => Target.Double(16),
            "S20" => Target.Single(20),
            "S19" => Target.Single(19),
            "S1" => Target.Single(1),
            _ => Target.Triple(20)
        };
    }
}
