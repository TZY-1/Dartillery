@using Dartillery.Core.Models
@using Dartillery.Web.Services

<div class="simulation-controls">
    <!-- Player Attributes (always visible) -->
    <div class="param-group">
        <div class="param-header">
            <i class="bi bi-bullseye param-icon"></i>
            <label class="param-label">Accuracy</label>
            <span class="param-value">@GetAccuracyPercent().ToString("F0")%</span>
        </div>
        <input type="range" class="form-range"
               min="0.015" max="0.15" step="0.001"
               value="@SimulationService.CustomSigma.ToString(System.Globalization.CultureInfo.InvariantCulture)"
               @oninput="e => OnSliderInput(e, v => SimulationService.CustomSigma = v)"
               @onchange="OnParameterChanged" />
        <small class="param-desc">Base throw spread</small>
    </div>

    <div class="param-group">
        <div class="param-header">
            <i class="bi bi-battery-half param-icon"></i>
            <label class="param-label">Stamina</label>
            <span class="param-value">@GetStaminaPercent().ToString("F0")%</span>
        </div>
        <input type="range" class="form-range"
               min="0.0" max="0.02" step="0.001"
               value="@SimulationService.FatigueRate.ToString(System.Globalization.CultureInfo.InvariantCulture)"
               @oninput="e => OnSliderInput(e, v => SimulationService.FatigueRate = v)"
               @onchange="OnParameterChanged" />
        <small class="param-desc">Fatigue rate per throw</small>
    </div>

    <div class="param-group">
        <div class="param-header">
            <i class="bi bi-shield-fill param-icon"></i>
            <label class="param-label">Composure</label>
            <span class="param-value">@((SimulationService.PressureResistance * 100).ToString("F0"))%</span>
        </div>
        <input type="range" class="form-range"
               min="0.0" max="1.0" step="0.01"
               value="@SimulationService.PressureResistance.ToString(System.Globalization.CultureInfo.InvariantCulture)"
               @oninput="e => OnSliderInput(e, v => SimulationService.PressureResistance = v)"
               @onchange="OnParameterChanged" />
        <small class="param-desc">Resistance to pressure situations</small>
    </div>

    <div class="param-group">
        <div class="param-header">
            <i class="bi bi-hand-index param-icon"></i>
            <label class="param-label">Stability</label>
            <span class="param-value">@GetStabilityPercent().ToString("F0")%</span>
        </div>
        <input type="range" class="form-range"
               min="0.0" max="0.1" step="0.001"
               value="@SimulationService.MaxTremor.ToString(System.Globalization.CultureInfo.InvariantCulture)"
               @oninput="e => OnSliderInput(e, v => SimulationService.MaxTremor = v)"
               @onchange="OnParameterChanged" />
        <small class="param-desc">Max tremor when fatigued</small>
    </div>

    <!-- Behavioral Models (collapsible) -->
    <div class="models-section">
        <div class="models-header" @onclick="() => _showModels = !_showModels">
            <i class="bi bi-lightning"></i>
            <span>Models</span>
            <span class="model-count">@GetActiveModelCount()/5</span>
            <i class="bi bi-chevron-@(_showModels ? "up" : "down")" style="margin-left: auto;"></i>
        </div>
        @if (_showModels)
        {
            <div class="models-content">
                <div class="model-row">
                    <div class="model-info">
                        <i class="bi bi-lightning model-icon"></i>
                        <span class="model-name">Fatigue</span>
                    </div>
                    <label class="toggle-label">
                        <input type="checkbox" class="toggle-input"
                               checked="@SimulationService.EnableFatigue"
                               @onchange="e => OnToggleChanged(v => SimulationService.EnableFatigue = v, e)" />
                        <span class="toggle-track"><span class="toggle-thumb"></span></span>
                    </label>
                </div>

                <div class="model-row">
                    <div class="model-info">
                        <i class="bi bi-heart-pulse model-icon"></i>
                        <span class="model-name">Pressure</span>
                    </div>
                    <label class="toggle-label">
                        <input type="checkbox" class="toggle-input"
                               checked="@SimulationService.EnablePressure"
                               @onchange="e => OnToggleChanged(v => SimulationService.EnablePressure = v, e)" />
                        <span class="toggle-track"><span class="toggle-thumb"></span></span>
                    </label>
                </div>

                <div class="model-row">
                    <div class="model-info">
                        <i class="bi bi-fire model-icon"></i>
                        <span class="model-name">Momentum</span>
                    </div>
                    <label class="toggle-label">
                        <input type="checkbox" class="toggle-input"
                               checked="@SimulationService.EnableMomentum"
                               @onchange="e => OnToggleChanged(v => SimulationService.EnableMomentum = v, e)" />
                        <span class="toggle-track"><span class="toggle-thumb"></span></span>
                    </label>
                </div>

                <div class="model-row">
                    <div class="model-info">
                        <i class="bi bi-diagram-3 model-icon"></i>
                        <span class="model-name">Grouping</span>
                    </div>
                    <label class="toggle-label">
                        <input type="checkbox" class="toggle-input"
                               checked="@SimulationService.EnableGrouping"
                               @onchange="e => OnToggleChanged(v => SimulationService.EnableGrouping = v, e)" />
                        <span class="toggle-track"><span class="toggle-thumb"></span></span>
                    </label>
                </div>

                <div class="model-row">
                    <div class="model-info">
                        <i class="bi bi-crosshair model-icon"></i>
                        <span class="model-name">Target Difficulty</span>
                    </div>
                    <label class="toggle-label">
                        <input type="checkbox" class="toggle-input"
                               checked="@SimulationService.EnableTargetDifficulty"
                               @onchange="e => OnToggleChanged(v => SimulationService.EnableTargetDifficulty = v, e)" />
                        <span class="toggle-track"><span class="toggle-thumb"></span></span>
                    </label>
                </div>
            </div>
        }
    </div>
</div>

@code {
    [Parameter] public SimulationService SimulationService { get; set; } = null!;
    [Parameter] public EventCallback OnThrowExecuted { get; set; }

    private bool _showModels;

    private double GetAccuracyPercent() => Math.Clamp((1.0 - (SimulationService.CustomSigma / 0.15)) * 100.0, 0, 100);
    private double GetStaminaPercent() => Math.Clamp((1.0 - (SimulationService.FatigueRate / 0.02)) * 100.0, 0, 100);
    private double GetStabilityPercent() => Math.Clamp((1.0 - (SimulationService.MaxTremor / 0.1)) * 100.0, 0, 100);

    private int GetActiveModelCount()
    {
        var count = 0;
        if (SimulationService.EnableFatigue) count++;
        if (SimulationService.EnablePressure) count++;
        if (SimulationService.EnableMomentum) count++;
        if (SimulationService.EnableGrouping) count++;
        if (SimulationService.EnableTargetDifficulty) count++;
        return count;
    }

    private static void OnSliderInput(ChangeEventArgs e, Action<double> setter)
    {
        if (double.TryParse(e.Value?.ToString(), System.Globalization.NumberStyles.Any,
            System.Globalization.CultureInfo.InvariantCulture, out double value))
        {
            setter(value);
        }
    }

    private async Task OnParameterChanged()
    {
        SimulationService.SelectedSkillLevel = "Custom";
        SimulationService.RebuildSession();
        await OnThrowExecuted.InvokeAsync();
    }

    private async Task OnToggleChanged(Action<bool> setter, ChangeEventArgs e)
    {
        setter((bool)(e.Value ?? false));
        SimulationService.RebuildSession();
        await OnThrowExecuted.InvokeAsync();
    }
}
