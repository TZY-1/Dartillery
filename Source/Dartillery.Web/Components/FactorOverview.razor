@using Dartillery.Web.Services

<div class="factor-overview">
    <!-- Active Models Info -->
    <div class="models-summary">
        <h3 class="summary-title">Simulation Models</h3>
        <div class="model-status-list">
            @foreach (var model in GetModelStatuses())
            {
                <div class="model-status @(model.Active ? "model-active" : "model-inactive")">
                    <i class="bi @model.Icon"></i>
                    <span class="model-status-name">@model.Name</span>
                    @if (model.Active)
                    {
                        <span class="model-badge-on">ON</span>
                    }
                    else
                    {
                        <span class="model-badge-off">OFF</span>
                    }
                </div>
            }
        </div>

        @if (SimulationService.EnableFatigue && SimulationService.ThrowCount > 0)
        {
            <div class="tremor-indicator">
                <span class="tremor-label">Current Tremor</span>
                <div class="tremor-bar-track">
                    <div class="tremor-bar-fill" style="width: @GetTremorPercent().ToString("F1", System.Globalization.CultureInfo.InvariantCulture)%"></div>
                </div>
                <span class="tremor-value">@((SimulationService.CurrentTremor * 100).ToString("F1"))%</span>
            </div>
        }
    </div>
</div>

@code {
    [Parameter] public SimulationService SimulationService { get; set; } = null!;

    private double GetTremorPercent() => Math.Clamp((SimulationService.CurrentTremor / SimulationService.MaxTremor) * 100.0, 0, 100);

    private ModelInfo[] GetModelStatuses() =>
    [
        new("Fatigue", "bi-lightning", SimulationService.EnableFatigue),
        new("Pressure", "bi-heart-pulse", SimulationService.EnablePressure),
        new("Momentum", "bi-fire", SimulationService.EnableMomentum),
        new("Grouping", "bi-diagram-3", SimulationService.EnableGrouping),
        new("Target Difficulty", "bi-crosshair", SimulationService.EnableTargetDifficulty)
    ];

    private sealed record ModelInfo(string Name, string Icon, bool Active);
}
