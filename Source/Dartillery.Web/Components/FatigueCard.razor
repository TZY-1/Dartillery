@using Dartillery.Web.Services

<div class="factor-card @(!Svc.EnableFatigue ? "card-inactive" : "")">
    <div class="card-header">
        <i class="bi bi-lightning card-icon"></i>
        <span class="card-title">Fatigue</span>
        <label class="toggle-label">
            <input type="checkbox" class="toggle-input"
                   checked="@Svc.EnableFatigue"
                   @onchange="e => OnToggle(v => Svc.EnableFatigue = v, e)" />
            <span class="toggle-track"><span class="toggle-thumb"></span></span>
        </label>
    </div>
    <div class="card-body">
        <small class="card-desc">Simulates accuracy degradation over the course of a session. Choose a fatigue curve and tune how quickly and how much accuracy drops.</small>

        <!-- Model type dropdown -->
        <div class="slider-group">
            <div class="slider-header">
                <span class="slider-label">Model</span>
                <span class="slider-value">@Svc.FatigueModelType</span>
            </div>
            <select class="form-select"
                    value="@Svc.FatigueModelType"
                    @onchange="OnModelChanged">
                <option value="@FatigueModelType.Logarithmic">Logarithmic</option>
                <option value="@FatigueModelType.Linear">Linear</option>
                <option value="@FatigueModelType.None">None</option>
            </select>
            <small class="card-desc">
                @switch (Svc.FatigueModelType)
                {
                    case FatigueModelType.Logarithmic:
                        <span>Fast initial fatigue, then plateau — matches real fatigue patterns.</span>
                        break;
                    case FatigueModelType.Linear:
                        <span>Constant fatigue rate per throw — simple and predictable.</span>
                        break;
                    case FatigueModelType.None:
                        <span>No fatigue — accuracy never degrades.</span>
                        break;
                }
            </small>
        </div>

        <!-- Growth Rate slider (only for Logarithmic) -->
        @if (Svc.FatigueModelType == FatigueModelType.Logarithmic)
        {
            <div class="slider-group">
                <div class="slider-header">
                    <span class="slider-label">Growth Rate</span>
                    <span class="slider-value">@Svc.FatigueGrowthRate.ToString("F3")</span>
                </div>
                <input type="range" class="form-range"
                       min="0.001" max="0.05" step="0.001"
                       value="@Svc.FatigueGrowthRate.ToString(Inv)"
                       @oninput="e => OnSlider(e, v => Svc.FatigueGrowthRate = v)"
                       @onchange="OnChanged" />
                <small class="card-desc">How quickly fatigue reaches the plateau. Low = slow onset, high = rapid initial fatigue.</small>
            </div>
        }

        <!-- Stamina slider -->
        <div class="slider-group">
            <div class="slider-header">
                <span class="slider-label">Stamina</span>
                <span class="slider-value">@GetStaminaPercent().ToString("F0")%</span>
            </div>
            <input type="range" class="form-range"
                   min="0.0" max="0.02" step="0.001"
                   value="@Svc.FatigueRate.ToString(Inv)"
                   @oninput="e => OnSlider(e, v => Svc.FatigueRate = v)"
                   @onchange="OnChanged" />
            <small class="card-desc">Player endurance. High stamina = fatigue builds slowly. Low stamina = accuracy drops faster per throw.</small>
        </div>

        <!-- Stability slider -->
        <div class="slider-group">
            <div class="slider-header">
                <span class="slider-label">Stability</span>
                <span class="slider-value">@GetStabilityPercent().ToString("F0")%</span>
            </div>
            <input type="range" class="form-range"
                   min="0.0" max="0.1" step="0.001"
                   value="@Svc.MaxFatigue.ToString(Inv)"
                   @oninput="e => OnSlider(e, v => Svc.MaxFatigue = v)"
                   @onchange="OnChanged" />
            <small class="card-desc">Limits how much fatigue can accumulate. Current cap: @Svc.MaxFatigue.ToString("F3") sigma added to base at most.</small>
        </div>

        <div class="card-divider"></div>

        @if (Svc.EnableFatigue && Svc.ThrowCount > 0)
        {
            var effectiveSigma = Svc.CustomSigma + Svc.CurrentFatigue;
            var spreadIncrease = Svc.CustomSigma > 0 ? (Svc.CurrentFatigue / Svc.CustomSigma) * 100.0 : 0;

            <div class="diag-bar-row">
                <span class="diag-label">Fatigue</span>
                <div class="diag-bar-track">
                    <div class="diag-bar-fill bar-fatigue" style="width: @GetFatiguePct().ToString("F1", Inv)%"></div>
                </div>
                <span class="diag-bar-val">@GetFatiguePct().ToString("F0")%</span>
            </div>
            <div class="diag-row">
                <span class="diag-label">Fatigue Value</span>
                <span class="diag-val">@Svc.CurrentFatigue.ToString("F4")</span>
            </div>

            <div class="card-divider"></div>

            <!-- Sigma comparison: base vs effective -->
            <div class="diag-row">
                <span class="diag-label">Base Sigma</span>
                <span class="diag-val">@Svc.CustomSigma.ToString("F4")</span>
            </div>
            <div class="diag-row">
                <span class="diag-label">+ Fatigue</span>
                <span class="diag-val @(Svc.CurrentFatigue > 0.001 ? "warn" : "")">+@Svc.CurrentFatigue.ToString("F4")</span>
            </div>
            <div class="diag-row total">
                <span class="diag-label">Effective Sigma</span>
                <span class="diag-val highlight">@effectiveSigma.ToString("F4")</span>
            </div>

            @if (spreadIncrease > 0.5)
            {
                <div class="diag-detail warn">Spread is @spreadIncrease.ToString("F0")% wider than without fatigue</div>
            }

            <div class="diag-row" style="margin-top: 4px;">
                <span class="diag-label">After throws</span>
                <span class="diag-val">@Svc.ThrowCount</span>
            </div>
        }
        else if (!Svc.EnableFatigue)
        {
            <div class="diag-empty">Enable fatigue to simulate accuracy degradation</div>
        }
        else
        {
            <div class="diag-empty">Throw darts to see fatigue diagnostics</div>
        }
    </div>
</div>

@code {
    [Parameter] public SimulationService Svc { get; set; } = null!;
    [Parameter] public EventCallback OnParameterChanged { get; set; }

    private static readonly System.Globalization.CultureInfo Inv = System.Globalization.CultureInfo.InvariantCulture;

    private double GetStaminaPercent() => Math.Clamp((1.0 - (Svc.FatigueRate / 0.02)) * 100.0, 0, 100);
    private double GetStabilityPercent() => Math.Clamp((1.0 - (Svc.MaxFatigue / 0.1)) * 100.0, 0, 100);
    private double GetFatiguePct() => Svc.MaxFatigue > 0 ? Math.Clamp((Svc.CurrentFatigue / Svc.MaxFatigue) * 100.0, 0, 100) : 0;

    private static void OnSlider(ChangeEventArgs e, Action<double> setter)
    {
        if (double.TryParse(e.Value?.ToString(), System.Globalization.NumberStyles.Any, Inv, out var v))
            setter(v);
    }

    private async Task OnChanged()
    {
        Svc.SelectedSkillLevel = "Custom";
        Svc.RebuildSession();
        await OnParameterChanged.InvokeAsync();
    }

    private async Task OnModelChanged(ChangeEventArgs e)
    {
        if (Enum.TryParse<FatigueModelType>(e.Value?.ToString(), out var model))
        {
            Svc.FatigueModelType = model;
            Svc.SelectedSkillLevel = "Custom";
            Svc.RebuildSession();
            await OnParameterChanged.InvokeAsync();
        }
    }

    private async Task OnToggle(Action<bool> setter, ChangeEventArgs e)
    {
        setter((bool)(e.Value ?? false));
        Svc.RebuildSession();
        await OnParameterChanged.InvokeAsync();
    }
}
