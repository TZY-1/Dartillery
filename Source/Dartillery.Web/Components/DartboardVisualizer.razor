@using Dartillery.Core.Models

<div class="dartboard-container">
    <svg @ref="svgElementRef"
         viewBox="-1.2 -1.2 2.4 2.4"
         class="dartboard-svg @(EnableManualTargeting ? "manual-targeting" : "")"
         transform="scale(1, -1)"
         style="transform-origin: center;"
         @onclick="HandleSvgClick"
         @onmousemove="HandleMouseMove"
         @onmousemove:preventDefault
         @onmouseleave="HandleMouseLeave">
        <!-- Background -->
        <circle cx="0" cy="0" r="1.15" fill="#1a1a1a" />

        <!-- Double Ring -->
        @for (int i = 0; i < SectorCount; i++)
        {
            <path d="@GetSectorPath(i, DoubleRingInner, DoubleRingOuter)"
                  fill="@(i % 2 == 0 ? "#dc2626" : "#16a34a")"
                  stroke="#000"
                  stroke-width="0.002" />
        }

        <!-- Outer Single -->
        @for (int i = 0; i < SectorCount; i++)
        {
            <path d="@GetSectorPath(i, TripleRingOuter, DoubleRingInner)"
                  fill="@(i % 2 == 0 ? "#000" : "#f5f5f5")"
                  stroke="#000"
                  stroke-width="0.002" />
        }

        <!-- Triple Ring -->
        @for (int i = 0; i < SectorCount; i++)
        {
            <path d="@GetSectorPath(i, TripleRingInner, TripleRingOuter)"
                  fill="@(i % 2 == 0 ? "#dc2626" : "#16a34a")"
                  stroke="#000"
                  stroke-width="0.002" />
        }

        <!-- Inner Single -->
        @for (int i = 0; i < SectorCount; i++)
        {
            <path d="@GetSectorPath(i, OuterBullRadius, TripleRingInner)"
                  fill="@(i % 2 == 0 ? "#000" : "#f5f5f5")"
                  stroke="#000"
                  stroke-width="0.002" />
        }

        <!-- Outer Bull (Single Bull - Green) -->
        <circle cx="0" cy="0" r="@OuterBullRadius.ToString("F4", System.Globalization.CultureInfo.InvariantCulture)"
                fill="#16a34a"
                stroke="#000"
                stroke-width="0.002" />

        <!-- Inner Bull (Double Bull / Bullseye - Red) -->
        <circle cx="0" cy="0" r="@InnerBullRadius.ToString("F4", System.Globalization.CultureInfo.InvariantCulture)"
                fill="#dc2626"
                stroke="#000"
                stroke-width="0.002" />

       <!-- Numbers -->
        @for (int i = 0; i < SectorCount; i++)
        {
            var pos = GetSectorTextPosition(i);
            <g transform="scale(1, -1)">
                <text x="@pos.X.ToString("F4", System.Globalization.CultureInfo.InvariantCulture)"
                      y="@pos.Y.ToString("F4", System.Globalization.CultureInfo.InvariantCulture)"
                      text-anchor="middle"
                      dominant-baseline="middle"
                      fill="#fff"
                      font-size="0.1"
                      font-weight="bold"
                      font-family="Arial, sans-serif">
                    @SectorOrder[i]
                </text>
            </g>
        }

        <!-- Spread Shapes (follow mouse) -->
        @if (ShowSpreadCircle && BaseBounds != null && _mouseOver)
        {
            @* Effective spread shape (fatigue) — outer, only when fatigue is active *@
            @if (EffectiveBounds != null && !EffectiveBounds.Equals(BaseBounds))
            {
                @((MarkupString)EffectiveBounds.ToSvgElement(_mouseX, _mouseY,
                    "fill=\"rgba(239, 68, 68, 0.06)\" stroke=\"#ef4444\" stroke-width=\"0.006\" stroke-dasharray=\"0.015,0.01\" stroke-opacity=\"0.5\" pointer-events=\"none\""))
            }

            @* Base spread shape — inner *@
            @((MarkupString)BaseBounds.ToSvgElement(_mouseX, _mouseY,
                "fill=\"rgba(251, 191, 36, 0.08)\" stroke=\"#fbbf24\" stroke-width=\"0.008\" stroke-dasharray=\"0.02,0.01\" stroke-opacity=\"0.6\" pointer-events=\"none\""))
        }

        <!-- Throws Visualization -->
        @if (Throws != null && Throws.Any())
        {
            <g class="throws-layer">
                @foreach (var throw_ in Throws)
                {
                    var culture = System.Globalization.CultureInfo.InvariantCulture;

                    @if (ShowDeviationLines)
                    {
                        <!-- Deviation line from aim to hit -->
                        <line x1="@throw_.AimedPoint.X.ToString("F4", culture)"
                              y1="@throw_.AimedPoint.Y.ToString("F4", culture)"
                              x2="@throw_.HitPoint.X.ToString("F4", culture)"
                              y2="@throw_.HitPoint.Y.ToString("F4", culture)"
                              stroke="#fbbf24"
                              stroke-width="0.007"
                              stroke-dasharray="0.01,0.005"
                              stroke-opacity="0.7" />
                    }

                    <!-- Aim Point (Yellow) -->
                    <circle cx="@throw_.AimedPoint.X.ToString("F4", culture)"
                            cy="@throw_.AimedPoint.Y.ToString("F4", culture)"
                            r="0.015"
                            fill="#fbbf24"
                            stroke="#f59e0b"
                            stroke-width="0.005" />

                    <!-- Hit Point (Orange) -->
                    <circle cx="@throw_.HitPoint.X.ToString("F4", culture)"
                            cy="@throw_.HitPoint.Y.ToString("F4", culture)"
                            r="0.015"
                            fill="#f97316"
                            stroke="#ea580c"
                            stroke-width="0.005" />
                }
            </g>
        }

    </svg>
</div>
