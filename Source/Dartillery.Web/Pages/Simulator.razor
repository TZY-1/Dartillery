@page "/"
@using Dartillery.Web.Services
@using Dartillery.Web.Components
@inject SimulationService SimulationService
@implements IDisposable

<PageTitle>Dart Simulator - Dartillery</PageTitle>

<div class="simulator-dashboard">
    <div class="dashboard-toolbar">
        <SimulatorToolbar SimulationService="@SimulationService"
                          OnThrowExecuted="@OnThrowExecuted"
                          EnableZoom="@_enableZoom"
                          ZoomLevel="@_zoomLevel"
                          ZoomSize="@_zoomSize"
                          OnZoomChanged="@HandleZoomChanged" />
    </div>

    <div class="dashboard-board">
        <DartboardVisualizer Throws="@SimulationService.Throws.ToList()"
                             ShowDeviationLines="@ShowDeviationLines"
                             ShowSpreadCircle="@SimulationService.ShowSpreadCircle"
                             BaseBounds="@SimulationService.BaseBounds"
                             EffectiveBounds="@SimulationService.EffectiveBounds"
                             EnableManualTargeting="@SimulationService.EnableManualTargeting"
                             EnableGrouping="@SimulationService.EnableGrouping"
                             GroupingClusterRadius="@SimulationService.GroupingClusterRadius"
                             EnableZoom="@_enableZoom"
                             ZoomLevel="@_zoomLevel"
                             ZoomSize="@_zoomSize"
                             OnManualTargetSelected="@HandleManualTargetSelected" />
        <CompactStats SimulationService="@SimulationService" />
        <RecentThrowsStrip SimulationService="@SimulationService" />
    </div>

    <div class="dashboard-factors">
        <AccuracyCard Svc="@SimulationService" OnParameterChanged="@OnThrowExecuted" />
        <FatigueCard Svc="@SimulationService" OnParameterChanged="@OnThrowExecuted" />
        <PressureCard Svc="@SimulationService" OnParameterChanged="@OnThrowExecuted" />
        <MomentumCard Svc="@SimulationService" OnParameterChanged="@OnThrowExecuted" />
        <GroupingCard Svc="@SimulationService" OnParameterChanged="@OnThrowExecuted" />
        <TargetDifficultyCard Svc="@SimulationService" OnParameterChanged="@OnThrowExecuted" />
        <CalculationCard Svc="@SimulationService" />
    </div>
</div>

@code {
    private bool ShowDeviationLines { get; set; } = true;
    private bool _enableZoom;
    private double _zoomLevel = 0.08;
    private double _zoomSize = 0.64;

    protected override void OnInitialized()
    {
        SimulationService.OnStateChanged += StateHasChanged;
        SimulationService.RebuildSession();
    }

    private void OnThrowExecuted()
    {
        StateHasChanged();
    }

    private void HandleZoomChanged((bool Enabled, double Level, double Size) zoom)
    {
        _enableZoom = zoom.Enabled;
        _zoomLevel = zoom.Level;
        _zoomSize = zoom.Size;
        StateHasChanged();
    }

    private async Task HandleManualTargetSelected((double X, double Y) coordinates)
    {
        try
        {
            SimulationService.ThrowAtCoordinates(coordinates.X, coordinates.Y);
        }
        catch (InvalidOperationException)
        {
            return;
        }

        OnThrowExecuted();
    }

    public void Dispose()
    {
        SimulationService.OnStateChanged -= StateHasChanged;
    }
}
